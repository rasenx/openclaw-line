{
  "name": "@rasenx/openclaw-line",
  "version": "1.0.0",
  "description": "LINE Messaging API channel plugin for OpenClaw",
  "type": "module",
  "files": [
    "index.ts",
    "src/"
  ],
  "dependencies": {
    "@line/bot-sdk": "^9.0.0",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "openclaw": {
    "extensions": ["./index.ts"],
    "channel": {
      "id": "line",
      "label": "LINE",
      "docsPath": "/channels/line"
    },
    "install": {
      "npmSpec": "@rasenx/openclaw-line"
    }
  },
  "keywords": ["openclaw", "line", "plugin", "channel", "messaging"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rasenx/openclaw-line.git"
  }
}
