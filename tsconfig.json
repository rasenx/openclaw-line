{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "lib": ["ES2022"]
  },
  "include": ["index.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "src/**/*.test.ts"]
}
